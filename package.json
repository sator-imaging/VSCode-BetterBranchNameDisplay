{
  "name": "better-branch-name-display",
  "version": "1.9.1",
  "displayName": "Better Branch Name Display",
  "publisher": "sator-imaging",
  "description": "Source Control input field placeholder to show full branch name first",
  "icon": "icon-128px.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sator-imaging/VSCode-BetterBranchNameDisplay.git"
  },
  "galleryBanner": {
    "theme": "light",
    "color": "#FFFFFF"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "UI",
    "UX",
    "SCM",
    "Source Control"
  ],
  "extensionKind": [
    "ui"
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "__not_supported_at_Dec_2025__browser": "./out/extension.js",
  "extensionDependencies": [
    "vscode.git"
  ],
  "contributes": {
    "commands": [
      {
        "command": "betterBranchNameDisplay.switchToMain",
        "shortTitle": "Ⓜ️",
        "title": "Switch to main/master branch"
      },
      {
        "command": "betterBranchNameDisplay.fetchPrune",
        "shortTitle": "🧹",
        "title": "Fetch (Prune)"
      },
      {
        "command": "betterBranchNameDisplay.warning",
        "shortTitle": "⚠️",
        "title": "Not on main/master branch"
      },
      {
        "command": "betterBranchNameDisplay.conventionalCommits",
        "shortTitle": "🔀",
        "title": "Conventional Commits: fix, feat, build, ci, test, docs, refactor, perf, style, chore, revert"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "betterBranchNameDisplay.switchToMain",
          "when": "view == betterBranchNameDisplayView",
          "group": "navigation"
        },
        {
          "command": "betterBranchNameDisplay.fetchPrune",
          "when": "view == betterBranchNameDisplayView",
          "group": "navigation"
        }
      ],
      "scm/title": [
        {
          "command": "betterBranchNameDisplay.warning",
          "when": "scmProvider == git && betterBranchNameDisplay.isNotMain",
          "group": "notification@-1"
        },
        {
          "command": "betterBranchNameDisplay.switchToMain",
          "when": "scmProvider == git",
          "group": "navigation@310"
        },
        {
          "command": "betterBranchNameDisplay.fetchPrune",
          "when": "scmProvider == git",
          "group": "navigation@310"
        },
        {
          "command": "betterBranchNameDisplay.conventionalCommits",
          "when": "scmProvider == git",
          "group": "navigation@310"
        }
      ]
    },
    "views": {
      "scm": [
        {
          "id": "betterBranchNameDisplayView",
          "name": "Current Branch",
          "icon": "$(git-branch)",
          "type": "tree",
          "visibility": "visible",
          "initialSize": 0
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "echo No test at this moment  || node ./out/test/runTest.js",
    "package": "vsce package --allow-star-activation",
    "deploy": "vsce publish --allow-star-activation"
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.2.0",
    "@vscode/vsce": "^2.19.0",
    "eslint": "^8.28.0",
    "glob": "^8.0.3",
    "mocha": "^10.8.2",
    "typescript": "^4.9.3"
  }
}